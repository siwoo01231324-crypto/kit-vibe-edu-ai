# ============================================================
# 절대 실제 키를 여기 커밋하지 말 것
# 이 파일은 템플릿입니다. 실제 값은 .env.local 에 작성하세요.
# ============================================================

# Supabase — `npx supabase start` 실행 후 출력된 값을 복사하세요.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase start 출력 복사>
SUPABASE_SERVICE_ROLE_KEY=<supabase start 출력 복사>

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
